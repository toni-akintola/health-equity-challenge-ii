# Required for the tract policy proposal API (POST /api/tract/[id]/policy-proposal).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: enables web search so the LLM can look up state/county politics and context.
# Get a key at https://exa.ai (used for web_search tool in policy proposals).
# EXA_API_KEY=
